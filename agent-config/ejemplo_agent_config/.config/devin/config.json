{
  "read_config_from": {
    "cursor": true,
    "windsurf": true,
    "claude": true
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Exec(git)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(pnpm run test:*)",
      "Bash(npm run test:*)",
      "Bash(cargo test:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(prettier:*)",
      "Bash(eslint:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(playwright:*)",
      "Bash(rustfmt:*)",
      "Bash(shfmt:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr merge:*)",
      "Bash(pnpm publish:*)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(vercel:*)",
      "Bash(supabase db push:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r *)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(supabase db reset:*)"
    ]
  },
  "mcpServers": {
    "codebase-memory-mcp": {
      "command": "/home/alexendros/.local/bin/codebase-memory-mcp"
    }
  }
}
