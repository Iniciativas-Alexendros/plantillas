name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  no-latest-tag:
    name: prohibir :latest en imágenes
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Verificar ausencia de :latest
        run: |
          # Falla si algún compose file o Dockerfile referencia una imagen :latest
          set -o pipefail
          if grep -rn --include="docker-compose*.yml" --include="docker-compose*.yaml" --include="Dockerfile*" ':latest' .; then
            echo "ERROR: se encontraron imágenes sin versión explícita (:latest). Pinea la versión exacta."
            exit 1
          fi
          echo "OK: ninguna imagen usa :latest"

  validate-compose:
    name: validar docker compose
    runs-on: ubuntu-latest
    needs: no-latest-tag
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Validar sintaxis de todos los compose files
        run: |
          set -o pipefail
          # Itera sobre todos los docker-compose*.yml en subdirectorios
          ERRORS=0
          while IFS= read -r -d '' compose_file; do
            echo "→ Validando: $compose_file"
            docker compose -f "$compose_file" config --quiet || { echo "FALLO: $compose_file"; ERRORS=$((ERRORS + 1)); }
          done < <(find . -name "docker-compose*.yml" -o -name "docker-compose*.yaml" | sort | tr '\n' '\0')
          if [ "$ERRORS" -gt 0 ]; then
            echo "ERROR: $ERRORS compose file(s) con sintaxis inválida."
            exit 1
          fi
          echo "OK: todos los compose files son válidos"

  lint-yaml:
    name: yamllint
    runs-on: ubuntu-latest
    needs: no-latest-tag
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Instalar yamllint
        run: pip install yamllint --quiet

      - name: Lint YAML
        run: yamllint .

  hadolint:
    name: hadolint (Dockerfiles)
    runs-on: ubuntu-latest
    needs: no-latest-tag
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Lint Dockerfiles
        uses: hadolint/hadolint-action@v3.1.0
        with:
          recursive: true
          failure-threshold: warning

