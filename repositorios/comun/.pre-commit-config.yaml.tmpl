# .pre-commit-config.yaml — Plantilla genérica para repos consumidores
#
# Instalación:
#   pip install pre-commit
#   pre-commit install
#
# Uso:
#   - El bloque BASE y GITLEAKS son OBLIGATORIOS para todos los stacks.
#   - Los bloques por stack están comentados: descomenta el que corresponda a tu repo.
#   - Todos los revs están pineados por tag (no SHA, no HEAD, no latest).
#
# Verificar que todo pasa:
#   pre-commit run --all-files

repos:
  # ===========================================================================
  # BASE — Obligatorio para todos los stacks
  # ===========================================================================
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v5.0.0
    hooks:
      - id: trailing-whitespace
        args: ["--markdown-linebreak-ext=md"]
      - id: end-of-file-fixer
      - id: check-yaml
      - id: check-json
      - id: check-added-large-files
        args: ["--maxkb=500"]
      - id: check-merge-conflict
      - id: detect-private-key
      - id: check-case-conflict
      - id: mixed-line-ending
        args: ["--fix=lf"]

  # ===========================================================================
  # GITLEAKS — Secret scanning. Obligatorio para todos los stacks.
  # ===========================================================================
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.30.1
    hooks:
      - id: gitleaks

  # ===========================================================================
  # === JS/TS (descomentar en repos Node) ===
