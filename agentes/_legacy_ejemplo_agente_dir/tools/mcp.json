{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${PROJECT_ROOT}"],
      "description": "Acceso controlado al filesystem del proyecto"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "Integración con GitHub (PRs, issues, repos)"
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "description": "Leer contenido de URLs"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"],
      "description": "Operaciones git avanzadas"
    }
  },
  "toolSearch": {
    "enabled": true,
    "maxToolsPerQuery": 10,
    "descriptionEmbeddingModel": "text-embedding-3-small"
  }
}
