{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(env)",
      "Bash(python3:*)",
      "Bash(node --version)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "TodoWrite"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /:*)",
      "Bash(curl * | sh:*)",
      "Bash(wget * | sh:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/NOMBRE-HOOK-pre-bash.sh" }
        ]
      }
    ],
    "PostToolUse": [],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/NOMBRE-HOOK-session-start.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [],
    "Stop": []
  },

  "env": {
    "CLAUDE_LANG": "es"
  }
}
