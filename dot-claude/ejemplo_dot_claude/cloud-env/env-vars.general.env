# XEK-ENV v3.3 · Variables de entorno · variante "general" (ligera)
# Pega este bloque en el campo "Variables de entorno" del diálogo
# "Actualizar entorno en la nube" (https://claude.ai/code).
#
# Diferencia vs env-vars.env (minado): tiers AI/OFFICE/NET/DOCKER/LEGAL
# apagados por defecto. Frío ~20–40s. Enciéndelos cambiando =0 → =1
# y borrando el stamp del día.

# ─── Identidad ─────────────────────────────────────────────────────────
AUTHOR=Alexendros
AUTHOR_KEY=ALEXENDROS_BAAL
TZ=Europe/Madrid
LANG=es_ES.UTF-8
LC_ALL=es_ES.UTF-8

# ─── Topología XEK ─────────────────────────────────────────────────────
XEK_VERSION=3.3
XEK_ENV_NAME=general
XEK_HOME=/home/user
XEK_REPOS_HOME=/home/user/repos
XEK_PLANTILLAS=/home/user/plantillas
XEK_CACHE=/home/user/.cache/xek
XEK_STATE=/home/user/.local/state/xek
XEK_LOG=/home/user/.local/state/xek/session.log
XEK_LANG=es

# ─── Runtimes (mise los materializa) ───────────────────────────────────
NODE_VERSION=24
PYTHON_VERSION=3.13
GO_VERSION=1.24
BUN_AUTO_UPGRADE=1
BUN_INSTALL=/home/user/.bun

# ─── PATH (mise → local → cargo → bun → node22 → sys → go) ─────────────
PATH=/home/user/.local/share/mise/shims:/home/user/.local/bin:/home/user/.cargo/bin:/home/user/.bun/bin:/opt/node22/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/go/bin

# ─── mise ──────────────────────────────────────────────────────────────
MISE_TRUSTED_CONFIG_PATHS=/home/user
MISE_QUIET=1
MISE_USE_TOML=1

# ─── Compatibilidad OMNI v3.0 (legacy) ─────────────────────────────────
OMNI_MODE=interactive
OMNI_REPOS_HOME=/home/user/repos
OMNI_AUTO_DELAY=5

# ─── Comportamiento Claude Code ────────────────────────────────────────
CLAUDE_LANG=es
CLAUDE_CODE_DEFAULT_BRANCH=main
DISABLE_TELEMETRY=1
EDITOR=nano
PAGER=cat
GIT_PAGER=cat
FORCE_COLOR=1

# ─── Toolchain tuning ──────────────────────────────────────────────────
PIP_DISABLE_PIP_VERSION_CHECK=1
PIP_NO_INPUT=1
UV_LINK_MODE=copy
UV_HTTP_TIMEOUT=120
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
NODE_OPTIONS=--max-old-space-size=4096
NPM_CONFIG_FUND=false
NPM_CONFIG_AUDIT=false
COREPACK_ENABLE_DOWNLOAD_PROMPT=0
CARGO_NET_RETRY=10
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ─── Tiers (variante "general": ligera por defecto) ────────────────────
XEK_TIER_CORE=1
XEK_TIER_RUNTIMES=1
XEK_TIER_PY=1
XEK_TIER_SHELL=1
XEK_TIER_WEB=1
XEK_TIER_AI=0
XEK_TIER_OFFICE=0
XEK_TIER_NET=0
XEK_TIER_DOCKER=0
XEK_TIER_LEGAL=0

# ─── Conocimiento (apuntadores, no tokens) ─────────────────────────────
HF_HOME=/home/user/.cache/huggingface
HF_HUB_ENABLE_HF_TRANSFER=1
NOTION_API_VERSION=2025-09-03

# ─── Puertas cifradas (paths, no secretos) ─────────────────────────────
XEK_SECRETS_DIR=/home/user/.local/state/xek/secrets
SOPS_AGE_KEY_FILE=/home/user/.config/sops/age/keys.txt
