{
  "skillListingBudgetFraction": 0.07,
  "permissions": {
    "allow": [
      "Agent",
      "Bash(bash -n:*)",
      "Bash(chmod +x:*)",
      "Bash(cp:*)",
      "Bash(env)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(node --version)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(python3 --version)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "TodoWrite"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /)",
      "Bash(curl *|*sh)",
      "Bash(wget *|*sh)"
    ]
  },
  "hooks": {
    "enabled": true,
    "sources": ["hooks/"]
  },
  "skills": {
    "autoDiscover": true,
    "preload": []
  },
  "output": {
    "language": "es",
    "style": "concise"
  }
}
